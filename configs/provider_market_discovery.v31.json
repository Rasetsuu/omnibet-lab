    "decimal_odds",
    "line_raw",
    "line_value",
    "team_name_raw",
    "team_id",
    "player_name_raw",
    "player_id",
    "period_raw",
    "settlement_scope_guess",
    "mapped_market_id",
    "mapping_confidence",
    "needs_mapping",
    "suspended",
