  "historical_source_manifest_bundle": {
    "target_runtime": "rust",
    "required_manifest_fields": [
      "source_id",
      "provider",
      "source_role",
      "license_notes",
      "local_path",
      "expected_codec",
      "expected_columns",
      "season_start",
      "season_end",
      "sha256",
      "row_count",
      "observed_at_policy",
      "promotion_target"
    ],
    "allowed_codecs": ["csv", "json", "jsonl.gzip", "jsonl.zstd", "parquet.zstd"],
    "promotion_targets": ["bronze_raw_snapshot", "silver_candidate", "gold_feature_candidate"]
  },
  "settlement_and_closing_odds_targets": {
    "market_families": ["1x2", "totals", "btts", "team_totals", "double_chance", "draw_no_bet"],
    "settlement_required_fields": ["canonical_fixture_id", "market_key", "selection_key", "final_result", "settled_at", "label_created_at"],
    "closing_odds_required_fields": ["canonical_fixture_id", "market_key", "selection_key", "bookmaker", "closing_price_decimal", "captured_at", "source_id"],
    "paper_clv_required": true,
    "label_after_settlement_only": true
  },
  "coverage_readiness_report": {
    "minimum_ready_rows": 1000,
    "minimum_completed_seasons_per_primary_league": 3,
    "minimum_odds_coverage_ratio": 0.6,
    "minimum_settlement_coverage_ratio": 0.95,
    "blocker_reasons": [
      "missing_local_source_file",
      "hash_mismatch",
      "insufficient_season_window",
      "missing_odds_columns",
      "missing_settlement_labels",
      "identity_mapping_required",
      "market_mapping_required"
    ]
  },
  "first_dataset_build_plan": {
    "target_runtime": "rust",
    "storage_contract": "omnibet.storage_v2_compression_contract.v266_v270",
    "stages": [
      "verify_local_source_manifests",
      "materialize_bronze_candidates",
      "classify_bronze_rows",
      "run_identity_mapping_review",
      "run_market_mapping_review",
      "write_silver_candidates",
      "derive_gold_feature_candidates",
      "attach_settlement_labels_after_final",
      "emit_coverage_readiness_report"
    ],
    "forbidden_actions": ["random_split", "train_on_unsettled_games", "store_credentials", "live_provider_calls_in_ci"],
    "ready_for_training_after_phase": false
